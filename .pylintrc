[MESSAGES CONTROL]
# C0301 line-too-long        – long bioinformatics command strings are unavoidable
# C0415 import-outside-toplevel – used legitimately (sys.argv patch in tests)
# R0912 too-many-branches    – complex pipeline logic
# R0913 too-many-arguments   – CLI entry-points need many params
# R0914 too-many-locals      – large processing functions
# R0915 too-many-statements  – large processing functions
# R0917 too-many-positional  – CLI entry-points need many params (pylint ≥ 3)
# R1702 too-many-nested-blocks – deeply nested I/O handling
# W0621 redefined-outer-name – standard pytest fixture injection pattern
# W0718 broad-exception-caught – intentional top-level catch-all handlers
# duplicate-code             – pipeline stages share structural boilerplate
disable=duplicate-code,C0301,R0912,R1702,R0913,R0917,W0718,R0915,C0415,R0914,W0621

[FORMAT]
max-line-length=120
